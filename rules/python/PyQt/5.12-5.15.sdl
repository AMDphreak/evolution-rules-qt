repo "https://github.com/amdphreak/equivalence-rules-code"
ruleset "PyQt 5.12 to 5.15" {
    aliases "5.13" "5.14"
    
    // QRegExp deprecation
    replace "QtCore.QRegExp" "QtCore.QRegularExpression"
    note "QRegExp" "QRegExp is legacy; consider completing transition to QRegularExpression."
    
    // High DPI scaling (Automated in 5.14+)
    replace "Qt.AA_EnableHighDpiScaling" "None // Automated in PyQt 5.14+"
}

